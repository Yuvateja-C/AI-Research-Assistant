# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# OpenRouter (Primary LLM service)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash

# Groq API key (Fallback LLM service)
GROQ_API_KEY=your_groq_api_key_here

# Gemini API key (Used for document embedding generation)
GEMINI_API_KEY=your_gemini_api_key_here

# Razorpay Payment Gateway (Keys from: https://dashboard.razorpay.com/)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# Stripe Payment Gateway (Alternative checkout, optional)
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# SMTP Email configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=noreply@researchai.app
